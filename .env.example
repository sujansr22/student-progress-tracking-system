# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Database
POSTGRES_DB=spts_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# Field encryption — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email — configure with your SMTP provider (SendGrid, Gmail, etc.)
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=SPTS Platform
MAIL_PORT=587
MAIL_SERVER=smtp.sendgrid.net
